---
import Layout from '../layouts/Layout.astro';

const nav = [
  { label: 'How it works', href: '/about/how-it-works' },
  { label: 'Assist a loved one', href: '/family/assist' },
  { label: 'For Providers', href: '/providers' },
  { label: 'Locations', href: '#locations' },
  { label: 'About', href: '/about' },
];

const pillars = [
  {
    kicker: 'Speed',
    title: 'Weeks, not months',
    body: 'See a neurologist fast. In brain health, early action changes outcomes.',
  },
  {
    kicker: 'Care team',
    title: 'Everyone connected',
    body: 'One team for patients, caregivers, and providers — all on the same page.',
  },
  {
    kicker: 'Innovation',
    title: 'Advanced science, today',
    body: 'AI-powered assessments and the latest diagnostic tools in everyday practice.',
  },
  {
    kicker: 'Compassion',
    title: 'Built around real life',
    body: 'Designed around the realities of daily life — not just clinical protocols.',
  },
];

const howItWorks = [
  {
    title: 'Start today',
    body: 'Start with a simple 30-minute virtual screening from home. Our tech-enabled platform lets loved ones assist, even remotely.',
  },
  {
    title: 'Comprehensive assessments',
    body: 'Meet with a specialist within weeks — not years — for a thorough evaluation. Work directly with our care team to understand the path forward.',
  },
  {
    title: 'Work with the team',
    body: 'Get a clear care plan that works for your whole family. Our care team coordinates everything, keeping you involved and informed.',
  },
  {
    title: 'The latest science',
    body: 'Unlock access to the latest science, tools and therapeutics. Our care team will guide you on what\u2019s right for you.',
  },
];

const locations = [
  { city: 'Danvers', state: 'Massachusetts', href: '/locations/danvers' },
  { city: 'Telehealth', state: 'Massachusetts', href: '/locations/telehealth-ma' },
  { city: 'Irvine', state: 'California', href: '/locations/irvine' },
  { city: 'Bay Area', state: 'California', href: '/locations/bay-area' },
];

const startingPoints = [
  {
    kicker: 'I\u2019m a',
    title: 'Patient',
    body: 'You\u2019re noticing changes in memory or thinking — for yourself or someone close to you — and you want clear answers without the long wait.',
    cta: 'See how it works',
    href: '/about/how-it-works',
  },
  {
    kicker: 'I\u2019m a',
    title: 'Caregiver or family member',
    body: 'You\u2019re supporting a loved one through this and want help navigating care, finding resources, and knowing you\u2019re not alone.',
    cta: 'How to assist a loved one',
    href: '/family/assist',
  },
  {
    kicker: 'I\u2019m a',
    title: 'Referring provider',
    body: 'Your patients need cognitive care and you want a specialist partner who communicates clearly and moves fast.',
    cta: 'Information for providers',
    href: '/providers',
  },
];
---

<Layout>
  <!-- NAV -->
  <header class="sticky top-4 z-50 mx-4 md:mx-8">
    <div class="max-w-7xl mx-auto bg-white/80 backdrop-blur-md border border-[color:var(--color-border-soft)] rounded-[color:var(--radius-card)] rounded-3xl px-5 py-3 flex items-center justify-between shadow-sm">
      <a href="/" class="flex items-center gap-2">
        <img src="/assets/logo-green.png" alt="Mindspan" class="h-7 w-auto" />
      </a>
      <nav class="hidden lg:flex items-center gap-7 text-sm font-medium text-[color:var(--color-brand-green)]">
        {nav.map((n) => (
          <a href={n.href} class="hover:text-[color:var(--color-brand-orange)] transition-colors">{n.label}</a>
        ))}
      </nav>
      <a
        href="https://assessment.mindspan.co/"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 bg-[color:var(--color-brand-orange)] text-white font-semibold text-sm px-5 py-2.5 rounded-full hover:scale-[0.975] transition-transform"
      >
        Get assessed today
        <img src="/assets/arrow-right.svg" alt="" class="h-3 w-3 invert" />
      </a>
    </div>
  </header>

  <!-- HERO -->
  <section class="px-4 md:px-8 pt-12 md:pt-20 pb-16 md:pb-28">
    <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div>
        <h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl leading-[1.05] text-[color:var(--color-brand-green)] tracking-tight">
          Cognitive health, made personal and accessible <em class="not-italic text-[color:var(--color-brand-orange)]">today</em>.
        </h1>
        <p class="mt-6 text-base sm:text-lg text-[color:var(--color-brand-green)]/80 max-w-xl">
          In Alzheimer&rsquo;s care, timing changes everything. Many patients wait months — even years — to see a specialist. We move fast so we can start the right treatment while it can still slow the disease and protect what matters. We detect early, treat comprehensively, and connect you to the latest science.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="/about/how-it-works" class="inline-flex items-center gap-3 bg-[color:var(--color-brand-green)] text-white font-semibold px-7 py-4 rounded-full hover:scale-[0.975] transition-transform">
            How it works
            <span class="text-xs opacity-70">Learn about Mindspan</span>
          </a>
          <a href="https://assessment.mindspan.co/" target="_blank" rel="noopener" class="inline-flex items-center gap-3 border border-[color:var(--color-brand-green)] text-[color:var(--color-brand-green)] font-semibold px-7 py-4 rounded-full hover:bg-[color:var(--color-brand-green)] hover:text-white transition-colors">
            Take a free assessment
          </a>
        </div>
        <p class="mt-6 text-sm text-[color:var(--color-brand-green)]/60">Available in Massachusetts &amp; California</p>
      </div>
      <div class="relative">
        <img
          src="/assets/hero.png"
          srcset="/assets/68633237312d265c6fb56c78_hero2-p-500.png 500w, /assets/68633237312d265c6fb56c78_hero2-p-800.png 800w, /assets/68633237312d265c6fb56c78_hero2-p-1080.png 1080w, /assets/hero.png 1600w"
          sizes="(max-width: 1024px) 100vw, 50vw"
          alt="Mindspan care team with patient"
          class="w-full rounded-[20px] shadow-lg"
        />
      </div>
    </div>
  </section>

  <!-- GOALS / SUPPORT -->
  <section class="px-4 md:px-8 py-16 md:py-24 bg-[color:var(--color-sand)]">
    <div class="max-w-5xl mx-auto text-center">
      <h2 class="font-serif text-3xl sm:text-4xl lg:text-5xl leading-tight text-[color:var(--color-brand-green)]">
        Dealing with dementia is difficult. We know — we have been there. Whether you&rsquo;re a PCP, caregiver, or patient. <strong class="text-[color:var(--color-brand-orange)]">We&rsquo;ve got you.</strong>
      </h2>
      <div class="mt-10 flex justify-center">
        <a href="/about/how-it-works" class="inline-flex items-center gap-3 bg-[color:var(--color-brand-green)] text-white font-semibold px-7 py-4 rounded-full hover:scale-[0.975] transition-transform">
          Learn how it works
          <span class="text-xs opacity-70">Start today</span>
        </a>
      </div>
    </div>
  </section>

  <!-- FINANCE / PILLARS -->
  <section id="how" class="px-4 md:px-8 py-20 md:py-28">
    <div class="max-w-7xl mx-auto">
      <div class="max-w-3xl">
        <h2 class="font-serif text-3xl sm:text-4xl lg:text-5xl text-[color:var(--color-brand-green)] leading-tight">
          Cognitive care at the speed of real life.
        </h2>
        <p class="mt-5 text-lg text-[color:var(--color-brand-green)]/75">
          We don&rsquo;t replace the healthcare system. We strengthen it, connect it, and move it faster.
        </p>
      </div>
      <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {pillars.map((p) => (
          <div class="bg-white border border-black/10 rounded-[20px] p-7 flex flex-col">
            <span class="text-xs uppercase tracking-widest text-[color:var(--color-brand-orange)] font-semibold">{p.kicker}</span>
            <h3 class="mt-3 font-serif text-2xl text-[color:var(--color-brand-green)] leading-snug">{p.title}</h3>
            <p class="mt-3 text-[color:var(--color-brand-green)]/75 text-[15px] leading-relaxed">{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ASSIST A LOVED ONE -->
  <section class="px-4 md:px-8 py-16 md:py-24 bg-[color:var(--color-sand)]">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="font-serif text-3xl sm:text-4xl lg:text-5xl text-[color:var(--color-brand-green)]">
        Looking to assist a loved one?
      </h2>
      <div class="mt-8 flex justify-center">
        <a href="/family/assist" class="inline-flex items-center gap-3 bg-[color:var(--color-brand-orange)] text-white font-semibold px-7 py-4 rounded-full hover:scale-[0.975] transition-transform">
          Learn how to get started
          <span class="text-xs opacity-80">Built for families</span>
        </a>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS STEPS -->
  <section class="px-4 md:px-8 py-20 md:py-28">
    <div class="max-w-7xl mx-auto">
      <div class="max-w-3xl">
        <h2 class="font-serif text-3xl sm:text-4xl lg:text-5xl text-[color:var(--color-brand-green)] leading-tight">How it works</h2>
        <p class="mt-5 text-lg text-[color:var(--color-brand-green)]/75">
          A clear path forward, starting with answers this month. No lengthy waitlists, no uncertainty — just straightforward care when you need it.
        </p>
      </div>
      <ol class="mt-12 grid md:grid-cols-2 lg:grid-cols-4 gap-5">
        {howItWorks.map((s, i) => (
          <li class="bg-white border border-black/10 rounded-[20px] p-7">
            <div class="text-5xl font-serif text-[color:var(--color-brand-orange)]">{String(i + 1).padStart(2, '0')}</div>
            <h3 class="mt-4 font-serif text-2xl text-[color:var(--color-brand-green)]">{s.title}</h3>
            <p class="mt-3 text-[color:var(--color-brand-green)]/75 text-[15px] leading-relaxed">{s.body}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- DIGITAL TWIN / FUTURE -->
  <section class="px-4 md:px-8 py-20 md:py-28 bg-[color:var(--color-brand-green)] text-white">
    <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-xs uppercase tracking-widest text-[color:var(--color-brand-orange)] font-semibold">The future of cognitive health</p>
        <h2 class="mt-4 font-serif text-3xl sm:text-4xl lg:text-5xl leading-tight">Your own digital twin</h2>
        <p class="mt-5 text-white/75 text-lg leading-relaxed">
          Imagine a personal digital version of your brain — a &ldquo;digital twin&rdquo; — helping your care team truly understand and support your cognitive health. Trained on real-patient data from over 70,000 Alzheimer&rsquo;s patients and 20 years of studies.
        </p>
      </div>
      <img src="/assets/digital-brain.jpg" alt="Digital brain twin visualization" class="w-full rounded-[20px] shadow-xl" />
    </div>
  </section>

  <!-- LOCATIONS -->
  <section id="locations" class="px-4 md:px-8 py-20 md:py-28">
    <div class="max-w-7xl mx-auto">
      <div class="max-w-3xl">
        <h2 class="font-serif text-3xl sm:text-4xl lg:text-5xl text-[color:var(--color-brand-green)] leading-tight">Our locations</h2>
        <p class="mt-5 text-lg text-[color:var(--color-brand-green)]/75">
          Mindspan is open and seeing patients across Massachusetts and California. Book an appointment at any of our locations today.
        </p>
      </div>
      <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {locations.map((l) => (
          <a href={l.href} class="group bg-[color:var(--color-brand-green)] text-white rounded-[20px] p-7 hover:bg-[color:var(--color-brand-green-light)] transition-colors">
            <p class="text-xs uppercase tracking-widest text-[color:var(--color-brand-orange)] font-semibold">Appointments open</p>
            <h3 class="mt-4 font-serif text-3xl">{l.city}</h3>
            <p class="mt-1 text-white/75">{l.state}</p>
            <p class="mt-6 text-sm text-white/80 group-hover:text-white">Visit {l.city} clinic →</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- STARTING POINT -->
  <section class="px-4 md:px-8 py-20 md:py-28 bg-[color:var(--color-sand)]">
    <div class="max-w-7xl mx-auto">
      <div class="max-w-3xl">
        <p class="text-xs uppercase tracking-widest text-[color:var(--color-brand-orange)] font-semibold">We&rsquo;re here to help</p>
        <h2 class="mt-4 font-serif text-3xl sm:text-4xl lg:text-5xl text-[color:var(--color-brand-green)] leading-tight">
          Mindspan is here for you. Let&rsquo;s find your starting point.
        </h2>
        <p class="mt-5 text-lg text-[color:var(--color-brand-green)]/75">
          Looking for help with memory concerns can feel overwhelming — we get it. Pick the option below that sounds like you, and we&rsquo;ll point you in the right direction.
        </p>
      </div>
      <div class="mt-12 grid md:grid-cols-3 gap-5">
        {startingPoints.map((s) => (
          <a href={s.href} class="bg-white border border-black/10 rounded-[20px] p-8 hover:border-[color:var(--color-brand-orange)] transition-colors flex flex-col">
            <p class="text-sm text-[color:var(--color-brand-green)]/60">{s.kicker}</p>
            <h3 class="mt-2 font-serif text-3xl text-[color:var(--color-brand-green)]">{s.title}</h3>
            <p class="mt-4 text-[15px] text-[color:var(--color-brand-green)]/75 leading-relaxed flex-1">{s.body}</p>
            <p class="mt-6 text-sm font-semibold text-[color:var(--color-brand-orange)]">{s.cta} →</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER CTA -->
  <section class="px-4 md:px-8 py-20 md:py-28 bg-[color:var(--color-brand-green)] text-white">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="font-serif text-3xl sm:text-4xl lg:text-5xl leading-tight">
        See a specialist in weeks, not months or years. Early diagnosis means better outcomes — and more time with the people who matter most.
      </h2>
      <div class="mt-10 flex justify-center">
        <a href="https://assessment.mindspan.co/" target="_blank" rel="noopener" class="inline-flex items-center gap-3 bg-[color:var(--color-brand-orange)] text-white font-semibold px-8 py-4 rounded-full hover:scale-[0.975] transition-transform">
          Begin today
          <img src="/assets/arrow-right.svg" alt="" class="h-3 w-3 invert" />
        </a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-[color:var(--color-brand-green)] text-white/80 px-4 md:px-8 pt-16 pb-10 border-t border-white/10">
    <div class="max-w-7xl mx-auto grid md:grid-cols-2 lg:grid-cols-5 gap-10">
      <div class="lg:col-span-2">
        <img src="/assets/logo-white.png" alt="Mindspan" class="h-10 w-auto" />
        <p class="mt-6 text-sm max-w-sm">Expert cognitive care, without the wait. Clinics in Massachusetts and California.</p>
      </div>
      <div>
        <p class="text-white font-semibold mb-4">Patients</p>
        <ul class="space-y-2 text-sm">
          <li><a href="/about/how-it-works" class="hover:text-white">How it works</a></li>
          <li><a href="https://assessment.mindspan.co/" class="hover:text-white">Free assessment</a></li>
        </ul>
      </div>
      <div>
        <p class="text-white font-semibold mb-4">Family</p>
        <ul class="space-y-2 text-sm">
          <li><a href="/family" class="hover:text-white">Mindspan for families</a></li>
          <li><a href="/family/assist" class="hover:text-white">Introduce a loved one</a></li>
        </ul>
      </div>
      <div>
        <p class="text-white font-semibold mb-4">About</p>
        <ul class="space-y-2 text-sm">
          <li><a href="/about" class="hover:text-white">About Mindspan</a></li>
          <li><a href="/contact" class="hover:text-white">Contact us</a></li>
        </ul>
      </div>
    </div>
    <div class="max-w-7xl mx-auto mt-14 pt-8 border-t border-white/10 flex flex-wrap gap-4 justify-between text-xs">
      <p>&copy; 2026 Mindspan</p>
      <div class="flex gap-6">
        <a href="/legal/terms" class="hover:text-white">Terms</a>
        <a href="/legal/privacy" class="hover:text-white">Privacy</a>
        <a href="/legal/consent" class="hover:text-white">Informed consent</a>
      </div>
    </div>
  </footer>
</Layout>
